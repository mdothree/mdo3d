{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "divination/oracle-card",
  "title": "Oracle Card",
  "category": "widgets",
  "icon": "heart",
  "description": "Display a daily oracle card reading with beautiful spiritual design",
  "keywords": ["oracle", "card", "divination", "spiritual", "tarot"],
  "version": "1.0.0",
  "textdomain": "divination-blocks",
  "attributes": {
    "showKeywords": {
      "type": "boolean",
      "default": true
    },
    "showGuidance": {
      "type": "boolean",
      "default": true
    },
    "cardStyle": {
      "type": "string",
      "default": "default"
    },
    "allowRedraw": {
      "type": "boolean",
      "default": false
    }
  },
  "supports": {
    "html": false,
    "align": ["wide", "full"],
    "spacing": {
      "margin": true,
      "padding": true
    }
  },
  "editorScript": "file:./edit.js",
  "script": "file:./frontend.js",
  "style": "file:./style.css",
  "editorStyle": "file:./editor.css"
}
