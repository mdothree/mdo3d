# Shopify App Configuration
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here
SCOPES=read_products,write_products,read_orders,write_discounts
HOST=https://your-app-url.com

# App URLs
APP_URL=https://your-app-url.com
SHOPIFY_APP_URL=https://your-shop.myshopify.com

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/shopify_oracle

# Billing
BILLING_PLAN_NAME=Oracle Insights
BILLING_AMOUNT=29.99
BILLING_INTERVAL=EVERY_30_DAYS

# Environment
NODE_ENV=development
PORT=3000
