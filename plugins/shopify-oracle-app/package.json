{
  "name": "shopify-oracle-app",
  "version": "1.0.0",
  "description": "Shopify app for oracle card product recommendations and spiritual e-commerce features",
  "main": "server/index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node --watch server/index.js",
    "client": "cd client && vite",
    "build": "cd client && vite build",
    "start": "NODE_ENV=production node server/index.js",
    "tunnel": "ngrok http 3000",
    "setup": "npm install && cd client && npm install"
  },
  "keywords": [
    "shopify",
    "app",
    "oracle",
    "divination",
    "spiritual",
    "e-commerce"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@shopify/shopify-api": "^9.0.0",
    "@shopify/shopify-app-express": "^3.0.0",
    "@shopify/shopify-app-session-storage-memory": "^3.0.0",
    "express": "^4.18.2",
    "dotenv": "^16.4.5",
    "prisma": "^5.9.0",
    "@prisma/client": "^5.9.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "ngrok": "^5.0.0-beta.2"
  }
}
