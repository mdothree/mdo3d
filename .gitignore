# ─────────────────────────────────────────
# API Keys & Secrets - NEVER COMMIT
# ─────────────────────────────────────────
.env
.env.*
.env.local
.env.development
.env.production
*.local.env
**/config/local*.js
**/config/secret*.js
**/keys/*.json
**/credentials/*.json
**/service-accounts/*.json
*.pem
*.key
credentials.json
secrets.json
keys.json
tokens.json

# ─────────────────────────────────────────
# Setup Scripts with Hardcoded Keys
# ─────────────────────────────────────────
*payment-link*.js
*create-*.js
setup-*.js
deploy-*.js

# ─────────────────────────────────────────
# Environment Config with Real Values
# ─────────────────────────────────────────
**/env.js
**/config.js
**/firebase-config.js
**/stripe-config.js
# Allow these patterns but NOT with real values:
# - public/js/config/env.example.js (template only)
# - public/js/config/env.local.js (gitignored)

